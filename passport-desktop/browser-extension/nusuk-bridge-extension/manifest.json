{
  "manifest_version": 3,
  "name": "Nusuk Bridge Extension",
  "description": "Bridge automation commands between passport-desktop app and Nusuk tab.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "tabs",
    "nativeMessaging",
    "scripting"
  ],
  "host_permissions": [
    "https://masar.nusuk.sa/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://masar.nusuk.sa/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Nusuk Bridge"
  }
}
