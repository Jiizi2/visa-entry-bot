{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "passport-desktop",
  "version": "0.1.0",
  "identifier": "com.visaentry.passportdesktop",
  "build": {
    "devUrl": "http://127.0.0.1:1430",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Passport Entry Assistant",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.xz.style; font-src 'self' https://fonts.xz.style data:; img-src 'self' data: blob: file:; connect-src 'self' https://masar.nusuk.sa https://*.nusuk.sa;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
