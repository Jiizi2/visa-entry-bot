{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "EntryMate By Ghaniya",
    "version":  "1.0.0",
    "identifier":  "com.ghaniya.entrymate",
    "build":  {
                  "devUrl":  "http://127.0.0.1:1420",
                  "frontendDist":  "../src"
              },
    "app":  {
                "withGlobalTauri":  true,
                "windows":  [
                                {
                                    "url":  "index.html",
                                    "title":  "EntryMate By Ghaniya",
                                    "width":  1440,
                                    "height":  920,
                                    "center":  true,
                                    "minWidth":  1120,
                                    "minHeight":  760,
                                    "backgroundColor":  "#f9f9fd",
                                    "decorations":  false,
                                    "backgroundThrottling":  "disabled"
                                }
                            ],
                "security":  {
                                 "csp":  "default-src \u0027self\u0027; script-src \u0027self\u0027; style-src \u0027self\u0027 \u0027unsafe-inline\u0027; font-src \u0027self\u0027 data:; img-src \u0027self\u0027 data: blob: file: asset: http://asset.localhost https://asset.localhost; connect-src \u0027self\u0027 http://ipc.localhost https://masar.nusuk.sa https://*.nusuk.sa;"
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ]
               }
}
