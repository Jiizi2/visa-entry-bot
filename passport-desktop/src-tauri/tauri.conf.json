{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EntryMate By Ghaniya",
  "version": "1.0.0",
  "identifier": "com.ghaniya.entrymate",
  "build": {
    "devUrl": "http://127.0.0.1:1430",
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "url": "index.html",
        "title": "EntryMate By Ghaniya",
        "width": 1440,
        "height": 920,
        "center": true,
        "minWidth": 1120,
        "minHeight": 760,
        "backgroundColor": "#f9f9fd",
        "decorations": false,
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: file: asset: http://asset.localhost https://asset.localhost; connect-src 'self' http://ipc.localhost https://masar.nusuk.sa https://*.nusuk.sa;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
